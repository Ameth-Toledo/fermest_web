# Backend REST API (auth, usuarios, sensores)
VITE_API_URL=http://localhost:8000/api

# Backend WebSocket (si está vacío, se deriva de VITE_API_URL reemplazando http→ws)
VITE_WS_URL=ws://localhost:8000

# Backend IA (algoritmo genético, experimentos, simulación)
VITE_AI_API_URL=http://localhost:8001

# Chatbot (Nich-ká AI)
VITE_API_KEY_CHATBOT=your_api_key_here
VITE_NAME_CHATBOT=Nich-káBot
